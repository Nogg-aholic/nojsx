{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "nojsx",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src/*.tsx", "src/**/*.tsx", "src/**/*.css"]
}
