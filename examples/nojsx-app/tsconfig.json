{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "nojsx",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rewriteRelativeImportExtensions": true,
    "types": ["node", "bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src/*.tsx", "src/*.ts", "src/**/*.tsx", "src/**/*.ts", "src/**/*.css", "script/*.ts"]
}
