{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "bun"],
    "sourceMap": true,
    "declaration": false,
    "outDir": "./dist/scripts",
    "rootDir": "./scripts",
    "skipLibCheck": true
  },
  "include": ["./scripts/**/*.ts"],
  "exclude": [
    "./node_modules",
    "./dist",
    "./packages"
  ]
}
