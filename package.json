{
	"name": "nojsx",
	"version": "1.0.104",
	"type": "module",
	"scripts": {
		"clean:dist": "bun ./scripts/clean-dist.ts",
		"build": "bun ./scripts/compile.ts",
		"compile": "bun ./scripts/compile.ts --pack",
		"pack:tgz": "bun ./scripts/compile.ts --pack"
	},
	"bin": {
		"nojsx-generate-component-loaders": "./dist/scripts/generate-component-loaders.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./jsx-runtime": {
			"types": "./dist/jsx-runtime.d.ts",
			"import": "./dist/jsx-runtime.js"
		},
		"./jsx-dev-runtime": {
			"types": "./dist/jsx-dev-runtime.d.ts",
			"import": "./dist/jsx-dev-runtime.js"
		}
	},
	"files": [
		"src/core/styles",
		"configs/tailwind",
		"dist"
	],
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.5.2",
		"bun": "latest",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@nogg-aholic/nrpc": "https://github.com/Nogg-aholic/nRPC/releases/download/v0.1.3/nogg-aholic-nrpc-0.1.3.tgz"
	}
}
