{
	"name": "nojsx",
	"version": "1.0.24",
	"type": "module",
	"scripts": {
		"clean:dist": "bun scripts/clean-dist.ts",
		"build": "bun run clean:dist && bunx tsc -p tsconfig.json && bun scripts/copy-src-dts-to-dist.ts && bunx tsc -p tsconfig.scripts.json && bun scripts/assert-dist-relative-import-extensions.ts",
		"compile": "bun run pack:tgz",
		"pack:tgz": "bun run clean:dist && bun run build && bun scripts/pack-tgz.ts",
		"refresh:examples": "bun scripts/refresh-examples.ts",
		"release:examples": "bun scripts/refresh-examples.ts",
		"example:minimal": "npm --prefix ./examples/nojsx-minimal install && npm --prefix ./examples/nojsx-minimal run build",
		"test:tgz:minimal": "bun run pack:tgz && npm --prefix ./examples/nojsx-minimal install && npm --prefix ./examples/nojsx-minimal run build"
	},
	"bin": {
		"nojsx-build-css": "./dist/scripts/build-tailwind.js",
		"nojsx-generate-component-loaders": "./dist/scripts/generate-component-loaders.js"
	},
	"main": "./dist/jsx-runtime.js",
	"types": "./dist/jsx-runtime.d.ts",
	"exports": {
		".": {
			"types": "./dist/jsx-runtime.d.ts",
			"import": "./dist/jsx-runtime.js"
		},
		"./live-preview-runner": "./dist/live-preview/render-tsx-preview.js",
		"./jsx-runtime": {
			"types": "./dist/jsx-runtime.d.ts",
			"import": "./dist/jsx-runtime.js"
		},
		"./jsx-dev-runtime": {
			"types": "./dist/jsx-dev-runtime.d.ts",
			"import": "./dist/jsx-dev-runtime.js"
		},
		"./dev": {
			"types": "./dist/dev/build-nojsx-app-dev.d.ts",
			"import": "./dist/dev/build-nojsx-app-dev.js"
		},
		"./core/styles/nojsx.css": "./src/core/styles/nojsx.css",
		"./core/*": {
			"types": "./dist/core/*.d.ts",
			"import": "./dist/core/*.js"
		}
	},
	"files": [
		"src/core/styles",
		"configs/tailwind",
		"dist"
	],
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.5.2",
		"bun": "latest",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@tailwindcss/cli": "^4.2.2",
		"@tailwindcss/forms": "^0.5.11",
		"tailwindcss": "^4.2.2"
	}
}
