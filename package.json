{
	"name": "@nogg-aholic/nojsx",
	"description": "Browser-first JSX runtime with a small app server, route hosting, and server-backed component calls.",
	"version": "1.1.1",
	"homepage": "https://github.com/Nogg-aholic/noJSX#readme",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "bun ./scripts/compile.ts",
		"compile": "bun ./scripts/compile.ts --pack"
	},
	"bin": {
		"nojsx-build-css": "./dist/scripts/builder/consumer/tailwind.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./index.js": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./jsx-runtime": {
			"types": "./dist/jsx-runtime.d.ts",
			"import": "./dist/jsx-runtime.js"
		},
		"./jsx-dev-runtime": {
			"types": "./dist/jsx-dev-runtime.d.ts",
			"import": "./dist/jsx-dev-runtime.js"
		},
		"./builder": {
			"types": "./dist/scripts/builder/index.d.ts",
			"import": "./dist/scripts/builder/index.js"
		},
		"./start-nojsx-server": {
			"types": "./dist/scripts/builder/start-server.d.ts",
			"import": "./dist/scripts/builder/start-server.js"
		},
		"./build-nojsx-app-dev": {
			"types": "./dist/scripts/builder/build.d.ts",
			"import": "./dist/scripts/builder/build.js"
		},
		"./tailwind": {
			"types": "./dist/scripts/builder/consumer/tailwind.d.ts",
			"import": "./dist/scripts/builder/consumer/tailwind.js"
		},
		"./core/shell-page": {
			"types": "./dist/core/shell-page.d.ts",
			"import": "./dist/core/shell-page.js"
		},
		"./server/upstream-host-proxy": {
			"types": "./dist/core/transport/server/upstream-host-proxy.d.ts",
			"import": "./dist/core/transport/server/upstream-host-proxy.js"
		}
	},
	"files": [
		"src/core/styles",
		"configs/tailwind",
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nogg-aholic/noJSX"
	},
	"bugs": {
		"url": "https://github.com/Nogg-aholic/noJSX/issues"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"keywords": [
		"jsx",
		"runtime",
		"ui",
		"typescript",
		"bun",
		"components"
	],
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.6.0",
		"bun": "latest",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@nogg-aholic/nrpc": "^0.4.4",
		"@tailwindcss/cli": "^4.2.2",
		"@tailwindcss/forms": "^0.5.11",
		"tailwindcss": "^4.2.2"
	}
}
