{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "bun"],
    "jsxImportSource": "@nogg-aholic/nojsx",
    "paths": {
      "@nogg-aholic/nojsx/jsx-runtime": ["./src/jsx-runtime.ts"],
      "@nogg-aholic/nojsx/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"],
      "@nogg-aholic/nojsx": ["./src/index.ts"],
      "@nogg-aholic/nojsx/*": ["./src/*"]
    },
    "sourceMap": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx", "./src/core/types/**/*.d.ts"],
  "exclude": [
    "./src/**/*.js",
    "./scripts/**/*.js",
    "./node_modules",
    "./dist",
    "./examples"
  ]
}
